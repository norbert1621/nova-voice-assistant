{
  "name": "nova",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild --platform android",
    "postprebuild": "node -e \"const fs=require('fs');const src='assets/model';const dst='android/app/src/main/assets/model';if(fs.existsSync(src)){fs.mkdirSync('android/app/src/main/assets',{recursive:true});fs.cpSync(src,dst,{recursive:true});console.log('Vosk model copied to Android assets');}else{console.log('No Vosk model found at assets/model — skipping copy');}\""
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.9",
    "@supersami/rn-foreground-service": "^2.2.5",
    "axios": "^1.15.0",
    "babel-preset-expo": "^55.0.17",
    "expo": "~54.0.33",
    "expo-audio": "^55.0.13",
    "expo-av": "^16.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-file-system": "^55.0.16",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-speech-recognition": "^3.1.2",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-audio-record": "^0.2.2",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-vosk": "^2.1.7",
    "react-native-worklets": "^0.8.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
